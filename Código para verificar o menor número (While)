#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    int small = 99999999;
    int number;
    char e[20];

    while (1) {

        printf("Digite o numero inteiro para saber o menor [Digite Exit para sair]: ");
        scanf("%s", e);

        if (strcmp(e, "exit") == 0 || strcmp(e, "Exit") == 0) {
            break;
        }

        number = atoi(e);

        if (number < small) {
            small = number;
        }
    }

    printf("Menor numero: %d\n", small);

    return 0;
}
