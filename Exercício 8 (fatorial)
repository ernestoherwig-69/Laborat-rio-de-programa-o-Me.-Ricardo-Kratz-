#include <stdio.h>
    int main(){
        int n, fatorial=1;
        printf("Digite um numero para saber seu fatorial:");
        scanf("%d", &n);
        if(n==0){
            printf("O fatorial de 0 por definicao eh 1");
        }
        else{
            for(int i=1; i<=n; i++){
                fatorial*=i;
            }
            printf("%d! = %d", n, fatorial);
        }
        return 0;
    }
